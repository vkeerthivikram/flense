{
  "identifier": "default",
  "description": "Default capabilities for the Metadata Cleaner app",
  "windows": [
    {
      "label": "main"
    }
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "fs:allow-read-text-file",
    {
      "identifier": "fs:scope",
      "allow": ["**/*"]
    },
    "shell:allow-open"
  ]
}
